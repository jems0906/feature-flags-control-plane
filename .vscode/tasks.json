{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run control-plane",
      "type": "shell",
      "command": "go run .",
      "options": { "cwd": "${workspaceFolder}/control-plane" },
      "isBackground": true,
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Run microservice-demo",
      "type": "shell",
      "command": "go run .",
      "options": { "cwd": "${workspaceFolder}/microservice-demo" },
      "isBackground": true,
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Test control-plane",
      "type": "shell",
      "command": "go test ./... -v",
      "options": { "cwd": "${workspaceFolder}/control-plane" },
      "isBackground": false,
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Run all (control-plane + demo)",
      "dependsOn": ["Run control-plane", "Run microservice-demo"],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "group": "build"
    }
  ]
}
