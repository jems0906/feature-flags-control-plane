FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY microservice-demo/go.mod ./
COPY microservice-demo/ ./
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags "-s -w" -o /microservice-demo .

FROM scratch
COPY --from=builder /microservice-demo /microservice-demo
USER 65532:65532
EXPOSE 8081
ENTRYPOINT ["/microservice-demo"]
