FROM golang:1.22-alpine AS builder
WORKDIR /app

# Copy only go.mod first for better layer caching
COPY control-plane/go.mod .
COPY control-plane/ ./

# Build with aggressive optimizations for minimal binary
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags "-s -w" -o /control-plane .

FROM scratch
COPY --from=builder /control-plane /control-plane
USER 65532:65532
EXPOSE 8080
ENTRYPOINT ["/control-plane"]
